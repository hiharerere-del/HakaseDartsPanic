<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>はかせのダーツパニック Ver0.0.2 Base</title>
<style>
html,body{margin:0;background:#140b28;overflow:hidden}
canvas{display:block;width:100vw;height:100vh;background:#140b28}
</style>
</head>
<body>
<canvas id="game" width="450" height="800"></canvas>
<script>
const canvas=document.getElementById("game");
const ctx=canvas.getContext("2d");

class Player{
 constructor(){this.x=225;this.y=700;this.targetX=225;}
 update(){this.x+=(this.targetX-this.x)*0.2;}
 draw(){ctx.fillStyle="#FFD54F";ctx.beginPath();ctx.arc(this.x,this.y,22,0,Math.PI*2);ctx.fill();}
}

class Dart{
 constructor(x,y){this.x=x;this.y=y;this.speed=12;this.alive=true;}
 update(){this.y-=this.speed;if(this.y<-30)this.alive=false;}
 draw(){ctx.strokeStyle="#fff";ctx.beginPath();ctx.moveTo(this.x,this.y-10);ctx.lineTo(this.x,this.y+10);ctx.stroke();}
}

class DartManager{
class Enemy{

    constructor(x,y){

        this.x=x;
        this.y=y;

        this.radius=18;

        this.speed=2;

        this.alive=true;

    }

    update(){

        this.y+=this.speed;

        if(this.y>820){

            this.alive=false;

        }

    }

    draw(){

        ctx.fillStyle="#ff4444";

        ctx.beginPath();

        ctx.arc(
            this.x,
            this.y,
            this.radius,
            0,
            Math.PI*2
        );

        ctx.fill();

    }

}
 constructor(){this.list=[];this.cool=0;}
 update(player){
   if(--this.cool<=0){this.list.push(new Dart(player.x,player.y-25));this.cool=24;}
   this.list.forEach(d=>d.update());
   this.list=this.list.filter(d=>d.alive);
 }
 draw(){this.list.forEach(d=>d.draw());}
}

const player=new Player();
const darts=new DartManager();
const enemies=[];

for(let i=0;i<5;i++){

    enemies.push(

        new Enemy(
            60+i*80,
            -i*140
        )

    );

}

canvas.addEventListener("pointermove",e=>{
 const r=canvas.getBoundingClientRect();
 player.targetX=(e.clientX-r.left)*(450/r.width);
});

function loop(){
 ctx.fillStyle="#140b28";
 ctx.fillRect(0,0,450,800);
 player.update();
 darts.update(player);
 enemies.forEach(enemy=>enemy.update());

for(let i=enemies.length-1;i>=0;i--){

    if(!enemies[i].alive){

        enemies[i]=new Enemy(

            40+Math.random()*370,

            -50

        );

    }

}
 darts.draw();
 enemies.forEach(enemy=>enemy.draw());
 player.draw();
 ctx.fillStyle="#fff";
 ctx.font="20px sans-serif";
 ctx.fillText("Ver0.0.2 Base",20,30);
 requestAnimationFrame(loop);
}
loop();
</script>
</body>
</html>
